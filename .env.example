# ── Database ───────────────────────────────────────────────────────────────────
# asyncpg driver required — do NOT use psycopg2 URL scheme here
DATABASE_URL=postgresql+asyncpg://nexus:nexus@localhost:5432/nexus

# ── Cache / Pub-Sub ────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT Auth ───────────────────────────────────────────────────────────────────
# Generate a strong secret for production: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
ALGORITHM=HS256

# ── Password Hashing ───────────────────────────────────────────────────────────
# bcrypt work factor — 12 is the production minimum; lower only for test speed
BCRYPT_COST=12

# ── CORS ───────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000

# ── Rate Limiting ──────────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=100

# ── Runtime ────────────────────────────────────────────────────────────────────
# Values: development | staging | production
ENVIRONMENT=development

# ── Phase 2: LLM Provider ──────────────────────────────────────────────────────
# One of: groq (default), openai, anthropic
LLM_PROVIDER=groq

# Groq (default provider — fastest inference via LPU hardware)
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL=llama-3.1-8b-instant

# OpenAI (alternative provider)
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini

# Anthropic (alternative provider)
ANTHROPIC_API_KEY=your-anthropic-api-key-here
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# ── Phase 2: NPC Memory ────────────────────────────────────────────────────────
NPC_MEMORY_HOT_LIMIT=20
NPC_MEMORY_TTL_SECONDS=86400

# ── Dashboard ──────────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000
